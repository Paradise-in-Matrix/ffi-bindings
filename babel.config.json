{
    "presets": [
        [
            "@babel/preset-env",
            {
                "modules": "auto"
            }
        ],
        "@babel/preset-typescript"
    ],
    "plugins": [
        [
            "transform-rename-import",
            {
                "replacements": [
                    {
                        "original": "^(.*)\\?url$",
                        "replacement": "$1"
                    },
                    {
                        "original": "^(.*)\\.ts$",
                        "replacement": "$1.js"
                    }
                ]
            }
        ],
        "@babel/plugin-transform-class-properties",
        "@babel/plugin-transform-computed-properties"
    ]
}
